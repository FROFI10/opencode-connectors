{
  "name": "@opencode-connectors/browser",
  "version": "0.1.0",
  "private": true,
  "description": "MCP connector that drives a real Chrome browser via Playwright + stealth-plugin. Lets an agent navigate sites, click, type, extract data, and persist sessions across runs.",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "opencode-connector-browser": "dist/index.js"
  },
  "scripts": {
    "build": "tsc -b",
    "dev": "tsc -b --watch",
    "start": "node dist/index.js",
    "install-browser": "playwright install chromium",
    "clean": "rimraf dist"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.4",
    "playwright": "^1.49.1",
    "playwright-extra": "^4.3.6",
    "puppeteer-extra-plugin-stealth": "^2.11.2",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "rimraf": "^6.0.1",
    "typescript": "^5.6.3"
  },
  "engines": {
    "node": ">=20"
  }
}
